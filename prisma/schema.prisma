generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Booking {
  id                    String        @id @default(cuid())
  guestName             String
  guestEmail            String
  guestPhone            String
  numberOfGuests        Int           @default(2)
  numberOfAdults        Int  @default(2)
  numberOfTeens         Int  @default(0)   
  numberOfBabies        Int  @default(0)
  numberOfChildren2to6  Int  @default(0)
  numberOfChildren6to12 Int  @default(0)
  notes                 String?       @db.Text
  checkIn               DateTime
  checkOut              DateTime
  nights                Int
  basePrice             Float
  childPrice2to6        Float         @default(0)
  childPrice6to12       Float         @default(0)
  guestSurcharge        Float         @default(0)
  cleaningFee           Float         @default(0)
  touristTax            Float         @default(0)
  totalPrice            Float
  depositAmount         Float         @default(0)
  depositPaidAt         DateTime?
  extraServices         Json?
  extraServicesTotal    Float         @default(0)
  discountPercent       Float         @default(0)
  discountAmount        Float         @default(0)
  status                BookingStatus @default(PENDING)
  paymentIntentId       String?       @unique
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([checkIn, checkOut])
  @@index([status])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
  BLOCKED
}


model PricingRule {
  id              String         @id @default(cuid())
  name            String
  pricePerNight   Float
  weekendPrice    Float          @default(0)
  childPrice2to6  Float          @default(0)
  childPrice6to12 Float          @default(0)
  dateFrom        DateTime?
  dateTo          DateTime?
  minNights       Int            @default(2)
  minAdvanceDays  Int            @default(2)
  extraGuestFee   Float          @default(0)
  extraGuestFrom  Int            @default(3)
  isActive        Boolean        @default(true)
  priority        Int            @default(0)
  policyId        String?
  policy          BookingPolicy? @relation(fields: [policyId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
}

model BlockedPeriod {
  id        String   @id @default(cuid())
  dateFrom  DateTime
  dateTo    DateTime
  reason    String?
  createdAt DateTime @default(now())
}

model BookingPolicy {
  id             String        @id @default(cuid())
  name           String
  depositPercent Int           @default(30)
  freeCancelDays Int           @default(7)
  rules          PricingRule[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Discount {
  id              String    @id @default(cuid())
  name            String
  discountPercent Float
  stayFrom        DateTime
  stayTo          DateTime
  bookingFrom     DateTime?
  bookingTo       DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ExtraService {
  id          String          @id @default(cuid())
  name        String
  description String          @db.Text
  pricingType ServicePricing
  price       Float?
  imageUrl    String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum ServicePricing {
  PER_NIGHT
  PER_BOOKING
}

model HeroContent {
  id            String   @id @default("singleton")
  subtitle      String
  titleBefore   String
  titleEmphasis String
  titleAfter    String
  description   String   @db.Text
  highlights    Json
  slides        Json?
  updatedAt     DateTime @updatedAt
}